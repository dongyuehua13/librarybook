@model List<LibrarySeatSystem.Models.Seat>
@{
    ViewData["Title"] = "座位管理";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0"><i class="bi bi-grid-3x3-gap"></i> 座位管理</h3>
    <a asp-action="SeatCreate" class="btn btn-primary"><i class="bi bi-plus-circle"></i> 新增座位</a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>编号</th>
                <th>楼层</th>
                <th>区域</th>
                <th>描述</th>
                <th>状态</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var seat in Model)
            {
                <tr>
                    <td><strong>@seat.SeatNumber</strong></td>
                    <td>@seat.Floor 楼</td>
                    <td>@seat.Area</td>
                    <td>@(seat.Description ?? "-")</td>
                    <td>
                        @if (seat.IsActive)
                        {
                            <span class="badge bg-success">启用</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">禁用</span>
                        }
                    </td>
                    <td>
                        <a asp-action="SeatEdit" asp-route-id="@seat.Id" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil"></i> 编辑
                        </a>
                        <button class="btn btn-sm @(seat.IsActive ? "btn-outline-warning" : "btn-outline-success") toggle-btn" data-id="@seat.Id">
                            <i class="bi @(seat.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                            @(seat.IsActive ? "禁用" : "启用")
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $('.toggle-btn').click(function() {
            var btn = $(this);
            $.post('/Admin/SeatToggle', { id: btn.data('id') }, function(res) {
                if (!res.success) return;
                var row = btn.closest('tr');
                var badge = row.find('td').eq(4).children('span');
                if (res.isActive) {
                    badge.removeClass('bg-danger').addClass('bg-success').text('启用');
                    btn.removeClass('btn-outline-success').addClass('btn-outline-warning');
                    btn.find('i').removeClass('bi-play-circle').addClass('bi-pause-circle');
                    btn.text('禁用').prepend('<i class="bi bi-pause-circle"></i> ');
                } else {
                    badge.removeClass('bg-success').addClass('bg-danger').text('禁用');
                    btn.removeClass('btn-outline-warning').addClass('btn-outline-success');
                    btn.find('i').removeClass('bi-pause-circle').addClass('bi-play-circle');
                    btn.text('启用').prepend('<i class="bi bi-play-circle"></i> ');
                }
            });
        });
    </script>
}
