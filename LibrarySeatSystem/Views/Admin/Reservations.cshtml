@model LibrarySeatSystem.ViewModels.AdminReservationsViewModel
@{
    ViewData["Title"] = "预约管理";
    Layout = "_AdminLayout";
}

<h3 class="mb-3"><i class="bi bi-calendar-check"></i> 预约管理</h3>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label">状态</label>
                <select name="status" class="form-select">
                    <option value="">全部</option>
                    <option value="已预约" selected="@(ViewBag.Status == "已预约")">已预约</option>
                    <option value="已取消" selected="@(ViewBag.Status == "已取消")">已取消</option>
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label">开始日期</label>
                <input type="date" name="dateFrom" class="form-control" value="@ViewBag.DateFrom" />
            </div>
            <div class="col-auto">
                <label class="form-label">结束日期</label>
                <input type="date" name="dateTo" class="form-control" value="@ViewBag.DateTo" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> 筛选</button>
                <a asp-action="Reservations" class="btn btn-outline-secondary">重置</a>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>用户</th>
                <th>座位</th>
                <th>日期</th>
                <th>时段</th>
                <th>状态</th>
                <th>预约时间</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model.Items)
            {
                <tr>
                    <td>@r.Id</td>
                    <td>@r.UserName</td>
                    <td>@r.SeatNumber</td>
                    <td>@r.Date.ToString("yyyy-MM-dd")</td>
                    <td>@r.TimeSlot</td>
                    <td>
                        @if (r.Status == "已预约")
                        {
                            <span class="badge bg-success">已预约</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">已取消</span>
                        }
                    </td>
                    <td class="text-muted small">@r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Items.Any())
{
    <div class="alert alert-info">暂无匹配的预约记录</div>
}
