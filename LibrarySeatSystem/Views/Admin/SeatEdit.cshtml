@model LibrarySeatSystem.Models.Seat
@{
    ViewData["Title"] = "编辑座位 - " + Model.SeatNumber;
    Layout = "_AdminLayout";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-pencil"></i> 编辑座位 @Model.SeatNumber</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="mb-3">
                        <label class="form-label">座位编号</label>
                        <input asp-for="SeatNumber" class="form-control" required />
                    </div>
                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label">楼层</label>
                            <input asp-for="Floor" class="form-control" type="number" min="1" />
                        </div>
                        <div class="col">
                            <label class="form-label">区域</label>
                            <input asp-for="Area" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">描述</label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="mb-3 form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label class="form-check-label">启用</label>
                    </div>
                    <button type="submit" class="btn btn-warning w-100"><i class="bi bi-save"></i> 更新</button>
                    <a asp-action="Seats" class="btn btn-outline-secondary w-100 mt-2">返回</a>
                </form>
            </div>
        </div>
    </div>
</div>
