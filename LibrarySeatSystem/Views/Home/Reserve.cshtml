@model LibrarySeatSystem.Models.Seat
@{
    ViewData["Title"] = "预约座位 - " + Model.SeatNumber;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Seats">座位列表</a></li>
        <li class="breadcrumb-item"><a asp-action="Detail" asp-route-id="@Model.Id">@Model.SeatNumber</a></li>
        <li class="breadcrumb-item active">预约</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-plus-circle"></i> 预约座位 @Model.SeatNumber</h5>
            </div>
            <div class="card-body">
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i>
                    @Model.Floor 楼 · @Model.Area · @(!string.IsNullOrEmpty(Model.Description) ? Model.Description : "")
                </div>

                <form id="reserveForm" class="needs-validation" novalidate>
                    <input type="hidden" name="seatId" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label">预约日期</label>
                        <input type="date" name="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                        <div class="invalid-feedback">请选择预约日期</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label">开始时间</label>
                            <select name="startTime" class="form-select" required>
                                <option value="">请选择</option>
                                @for (int h = 8; h <= 21; h++)
                                {
                                    <option value="@(h):00">@h:00</option>
                                }
                            </select>
                            <div class="invalid-feedback">请选择开始时间</div>
                        </div>
                        <div class="col">
                            <label class="form-label">结束时间</label>
                            <select name="endTime" class="form-select" required>
                                <option value="">请选择</option>
                                @for (int h = 9; h <= 22; h++)
                                {
                                    <option value="@(h):00" selected="@(h == 9)">@h:00</option>
                                }
                            </select>
                            <div class="invalid-feedback">请选择结束时间</div>
                        </div>
                    </div>
                    <p class="text-muted small mb-3"><i class="bi bi-info-circle"></i> 单次预约最长4小时，每日最多预约2次</p>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-check-circle"></i> 提交预约
                    </button>
                </form>

                <div id="resultMsg" class="mt-3"></div>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1080;">
    <div id="reserveToast" class="toast align-items-center text-bg-success border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body" id="reserveToastMsg"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $('#reserveForm').submit(function(e) {
            var form = this;
            if (!form.checkValidity()) {
                e.preventDefault();
                e.stopPropagation();
                form.classList.add('was-validated');
                return;
            }
            e.preventDefault();
            var btn = $(this).find('button[type="submit"]');
            btn.prop('disabled', true);
            $.post('/Home/Reserve', $(this).serialize(), function(res) {
                var toastEl = document.getElementById('reserveToast');
                var toast = bootstrap.Toast.getOrCreateInstance(toastEl);
                var msgEl = $('#reserveToastMsg');
                if (res.success) {
                    toastEl.classList.remove('text-bg-danger');
                    toastEl.classList.add('text-bg-success');
                    msgEl.html(res.msg + '，<a href="/Home/MyReservations" class="text-white fw-bold">查看我的预约</a>');
                    toast.show();
                } else {
                    toastEl.classList.remove('text-bg-success');
                    toastEl.classList.add('text-bg-danger');
                    msgEl.text(res.msg);
                    toast.show();
                    btn.prop('disabled', false);
                }
            }).fail(function() {
                btn.prop('disabled', false);
            });
        });
    </script>
}
