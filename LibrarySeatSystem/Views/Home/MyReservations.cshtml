@model LibrarySeatSystem.ViewModels.MyReservationsViewModel
@{
    ViewData["Title"] = "我的预约";
}

<h2 class="mb-3"><i class="bi bi-calendar-check"></i> 我的预约</h2>

@if (!Model.HasReservations)
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> 暂无预约记录，<a asp-action="Seats">去预约座位</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-primary">
                <tr>
                    <th>座位</th>
                    <th>日期</th>
                    <th>时段</th>
                    <th>状态</th>
                    <th>预约时间</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Items)
                {
                    <tr>
                        <td><strong>@r.SeatNumber</strong></td>
                        <td>@r.Date.ToString("yyyy-MM-dd")</td>
                        <td>@r.TimeSlot</td>
                        <td>
                            @if (r.Status == "已预约")
                            {
                                <span class="badge bg-success">已预约</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">已取消</span>
                            }
                        </td>
                        <td class="text-muted small">@r.CreatedAt.ToString("MM-dd HH:mm")</td>
                        <td>
                            @if (r.CanCancel)
                            {
                                <button class="btn btn-sm btn-outline-danger cancel-btn" data-id="@r.Id">
                                    <i class="bi bi-x-circle"></i> 取消
                                </button>
                            }
                            else
                            {
                                <span class="text-muted small">--</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <script>
        $('.cancel-btn').click(function() {
            if (!confirm('确定取消该预约？')) return;
            var btn = $(this);
            $.post('/Home/Cancel', { id: btn.data('id') }, function(res) {
                if (res.success) {
                    location.reload();
                } else {
                    alert(res.msg);
                }
            });
        });
    </script>
}
