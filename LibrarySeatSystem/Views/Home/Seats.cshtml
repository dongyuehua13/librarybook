@model List<LibrarySeatSystem.ViewModels.SeatWithStatus>
@{
    ViewData["Title"] = "座位列表";
}

<h2 class="mb-3"><i class="bi bi-grid-3x3-gap"></i> 座位列表</h2>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label">楼层</label>
                <select name="floor" class="form-select" onchange="this.form.submit()">
                    <option value="">全部楼层</option>
                    @foreach (var f in ViewBag.Floors)
                    {
                        <option value="@f" selected="@(ViewBag.SelectedFloor == f)">@f 楼</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label">区域</label>
                <select name="area" class="form-select" onchange="this.form.submit()">
                    <option value="">全部区域</option>
                    @foreach (var a in ViewBag.Areas)
                    {
                        <option value="@a" selected="@(ViewBag.SelectedArea == a)">@a</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <a asp-action="Seats" class="btn btn-outline-secondary">重置</a>
            </div>
        </form>
    </div>
</div>

<div class="row g-3">
    @foreach (var seat in Model)
    {
        <div class="col-md-4 col-lg-3">
            <div class="card @(seat.IsOccupied ? "border-danger" : "border-success") h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="card-title mb-0">@seat.SeatNumber</h5>
                        @if (seat.IsOccupied)
                        {
                            <span class="badge bg-danger">已预约</span>
                        }
                        else
                        {
                            <span class="badge bg-success">空闲</span>
                        }
                    </div>
                    <p class="card-text text-muted small mb-1">
                        <i class="bi bi-building"></i> @seat.Floor 楼 · @seat.Area
                    </p>
                    @if (!string.IsNullOrEmpty(seat.Description))
                    {
                        <p class="card-text text-muted small">@seat.Description</p>
                    }
                    <a asp-action="Detail" asp-route-id="@seat.Id" class="btn btn-sm btn-outline-primary w-100">
                        <i class="bi bi-eye"></i> 查看详情
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">暂无符合条件的座位</div>
}
