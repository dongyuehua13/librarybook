@model HomeIndexViewModel
@{
    ViewData["Title"] = "首页";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card bg-light">
            <div class="card-body text-center">
                <h1 class="card-title">图书馆座位预约系统</h1>
                <p class="card-text text-muted">选择学生账号进入体验，或浏览座位查看实时状态</p>
            </div>
        </div>
    </div>
</div>

@if (!Model.IsLoggedIn)
{
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header"><strong>选择体验账号</strong></div>
                <div class="card-body">
                    <div class="row row-cols-1 row-cols-md-3 g-3">
                        @foreach (var student in Model.Students)
                        {
                            <div class="col">
                                <form method="post" action="/Home/SwitchUser">
                                    <input type="hidden" name="userId" value="@student.Id" />
                                    <button type="submit" class="btn btn-outline-primary w-100 py-3">
                                        <strong>@student.DisplayName</strong><br />
                                        <small class="text-muted">@@@student.Username</small>
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-footer text-center">
                    <a href="/Admin/Login" class="btn btn-dark">管理员登录</a>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="row mb-4">
        <div class="col-12">
            <div class="alert alert-success d-flex justify-content-between align-items-center">
                <span>当前已切换为 <strong>@Model.CurrentUserName</strong></span>
                <form method="post" action="/Home/Logout" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-outline-secondary">退出</button>
                </form>
            </div>
        </div>
    </div>
}

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card text-center h-100">
            <div class="card-body">
                <h5 class="card-title">总座位数</h5>
                <p class="display-6 text-primary">@Model.TotalActiveSeats</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center h-100">
            <div class="card-body">
                <h5 class="card-title">可用座位</h5>
                <p class="display-6 text-success">@Model.TotalActiveSeats</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center h-100">
            <div class="card-body">
                <h5 class="card-title">今日预约</h5>
                <p class="display-6 text-info">@Model.TodayReservations</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <a href="/Home/Seats" class="btn btn-primary btn-lg w-100 py-3">浏览座位</a>
    </div>
    <div class="col-md-6">
        <a href="/Home/MyReservations" class="btn btn-outline-primary btn-lg w-100 py-3 @(Model.IsLoggedIn ? "" : "disabled")">我的预约</a>
    </div>
</div>

@if (Model.AreaDistribution.Count > 0)
{
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header"><strong>区域分布</strong></div>
                <div class="card-body">
                    <div class="row row-cols-1 row-cols-md-3 g-3">
                        @foreach (var kv in Model.AreaDistribution)
                        {
                            <div class="col">
                                <div class="border rounded p-3 text-center">
                                    <h6>@kv.Key</h6>
                                    <span class="badge bg-primary fs-5">@kv.Value 个座位</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
