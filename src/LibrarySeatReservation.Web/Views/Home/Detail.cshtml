@model SeatDetailViewModel
@{
    ViewData["Title"] = "座位详情 - " + Model.SeatNumber;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">首页</a></li>
        <li class="breadcrumb-item"><a href="/Home/Seats">座位列表</a></li>
        <li class="breadcrumb-item active">座位详情</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-md-5">
        <div class="card">
            <div class="card-header"><strong>座位信息</strong></div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr>
                        <td class="text-muted" style="width:100px">编号</td>
                        <td><strong>@Model.SeatNumber</strong></td>
                    </tr>
                    <tr>
                        <td class="text-muted">楼层</td>
                        <td>@Model.Floor 楼</td>
                    </tr>
                    <tr>
                        <td class="text-muted">区域</td>
                        <td>@Model.Area</td>
                    </tr>
                    <tr>
                        <td class="text-muted">状态</td>
                        <td>
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">启用</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">已禁用</span>
                            }
                        </td>
                    </tr>
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <tr>
                            <td class="text-muted">描述</td>
                            <td>@Model.Description</td>
                        </tr>
                    }
                </table>
                <div class="mt-3">
                    @if (Model.IsCurrentUserLoggedIn)
                    {
                        <a href="/Home/Reserve/@Model.Id" class="btn btn-primary w-100">预约此座位</a>
                    }
                    else
                    {
                        <button class="btn btn-outline-secondary w-100" disabled>请先选择账号</button>
                        <p class="small text-muted mt-1 mb-0 text-center">请先选择学生账号后再预约</p>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card">
            <div class="card-header"><strong>预约记录</strong></div>
            <div class="card-body">
                @if (Model.ReservationRecords.Count == 0)
                {
                    <p class="text-muted text-center py-3 mb-0">暂无预约记录</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>日期</th>
                                    <th>开始</th>
                                    <th>结束</th>
                                    <th>状态</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Model.ReservationRecords)
                                {
                                    <tr>
                                        <td>@r.Date.ToString("yyyy-MM-dd")</td>
                                        <td>@r.StartTime.ToString("HH:mm")</td>
                                        <td>@r.EndTime.ToString("HH:mm")</td>
                                        <td>
                                            @if (r.Status == "已预约")
                                            {
                                                <span class="badge bg-danger">已预约</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@r.Status</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
