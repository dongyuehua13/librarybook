@model Seat
@{
    ViewData["Title"] = "预约提交 - " + Model.SeatNumber;
    var today = DateTime.Today.ToString("yyyy-MM-dd");
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">首页</a></li>
        <li class="breadcrumb-item"><a href="/Home/Seats">座位列表</a></li>
        <li class="breadcrumb-item active">预约提交</li>
    </ol>
</nav>

<div id="notification" class="alert d-none mb-4" role="alert"></div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><strong>预约座位</strong></div>
            <div class="card-body">
                <table class="table table-borderless mb-3">
                    <tr>
                        <td class="text-muted" style="width:80px">座位</td>
                        <td><strong>@Model.SeatNumber</strong></td>
                    </tr>
                    <tr>
                        <td class="text-muted">位置</td>
                        <td>@Model.Floor 楼 · @Model.Area</td>
                    </tr>
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <tr>
                            <td class="text-muted">描述</td>
                            <td>@Model.Description</td>
                        </tr>
                    }
                </table>

                <form id="reserveForm" class="needs-validation" novalidate>
                    <input type="hidden" name="seatId" value="@Model.Id" />
                    <div class="mb-3">
                        <label class="form-label">预约日期</label>
                        <input type="date" name="date" class="form-control" min="@today" value="@today" required />
                        <div class="invalid-feedback">请选择预约日期</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">开始时间</label>
                        <input type="time" name="startTime" class="form-control" value="09:00" min="08:00" max="21:00" step="3600" required />
                        <div class="invalid-feedback">请选择开始时间</div>
                        <div class="form-text">可选 08:00 ~ 21:00，整点开始</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">结束时间</label>
                        <input type="time" name="endTime" class="form-control" value="10:00" min="09:00" max="22:00" step="3600" required />
                        <div class="invalid-feedback">请选择结束时间</div>
                        <div class="form-text">最晚 22:00 结束，时长 1~4 小时</div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2" id="submitBtn">提交预约</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('reserveForm').addEventListener('submit', function(e) {
            if (!this.checkValidity()) {
                e.preventDefault();
                e.stopPropagation();
                this.classList.add('was-validated');
                return;
            }
            e.preventDefault();
            const btn = document.getElementById('submitBtn');
            const notif = document.getElementById('notification');
            btn.disabled = true;
            btn.textContent = '提交中...';
            notif.classList.add('d-none');

            const form = new FormData(this);
            fetch('/Home/Reserve', {
                method: 'POST',
                body: new URLSearchParams(form)
            })
            .then(r => r.json())
            .then(data => {
                notif.classList.remove('d-none', 'alert-success', 'alert-danger');
                if (data.success) {
                    notif.classList.add('alert-success');
                    notif.innerHTML = data.message + '——<a href="/Home/MyReservations" class="alert-link">查看我的预约</a>';
                    document.getElementById('reserveForm').reset();
                } else {
                    notif.classList.add('alert-danger');
                    notif.textContent = data.message;
                }
            })
            .catch(() => {
                notif.classList.remove('d-none', 'alert-success', 'alert-danger');
                notif.classList.add('alert-danger');
                notif.textContent = '网络异常，请重试';
            })
            .finally(() => {
                btn.disabled = false;
                btn.textContent = '提交预约';
            });
        });

        var startInput = document.querySelector('[name="startTime"]');
        var endInput = document.querySelector('[name="endTime"]');
        startInput.addEventListener('change', function() {
            var parts = this.value.split(':');
            var h = parseInt(parts[0]) + 1;
            endInput.min = h < 10 ? '0' + h + ':00' : h + ':00';
            if (endInput.value && endInput.value <= this.value) {
                endInput.value = h < 10 ? '0' + h + ':00' : h + ':00';
            }
        });
    </script>
}
