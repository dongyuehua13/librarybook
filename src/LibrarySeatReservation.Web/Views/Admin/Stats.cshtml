@model AdminStats
@{
    ViewData["Title"] = "数据统计";
    Layout = "_AdminLayout";
}

<h4 class="mb-3">数据统计</h4>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body py-4">
                <div class="display-4 fw-bold text-primary">@Model.TotalActiveSeats</div>
                <div class="text-muted mt-1">可用座位数</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body py-4">
                <div class="display-4 fw-bold text-success">@Model.TotalReservations</div>
                <div class="text-muted mt-1">总预约次数</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body py-4">
                <div class="display-4 fw-bold text-warning">@Model.TodayReservations</div>
                <div class="text-muted mt-1">今日预约数</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header"><strong>座位热度排行</strong></div>
            <div class="card-body">
                @if (Model.SeatRankings.Count == 0)
                {
                    <p class="text-muted text-center my-3">暂无数据</p>
                }
                else
                {
                    @foreach (var item in Model.SeatRankings)
                    {
                        <div class="mb-2">
                            <div class="d-flex justify-content-between small mb-1">
                                <span>@item.SeatNumber</span>
                                <span class="text-muted">@item.Count 次</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-primary" style="width: @(item.Percentage)%"></div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header"><strong>近 14 日预约趋势</strong></div>
            <div class="card-body">
                @if (Model.DailyTrends.Count == 0)
                {
                    <p class="text-muted text-center my-3">暂无数据</p>
                }
                else
                {
                    @foreach (var item in Model.DailyTrends)
                    {
                        <div class="mb-2">
                            <div class="d-flex justify-content-between small mb-1">
                                <span>@item.Date.ToString("MM-dd")</span>
                                <span class="text-muted">@item.Count 次</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-success" style="width: @(item.Percentage)%"></div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
