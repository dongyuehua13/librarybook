@model AdminReservationsViewModel
@{
    ViewData["Title"] = "预约管理";
    Layout = "_AdminLayout";
    var currentStatus = Context.Request.Query["status"];
    var currentDateFrom = Context.Request.Query["dateFrom"];
    var currentDateTo = Context.Request.Query["dateTo"];
    var statuses = new[] { "", "已预约", "已取消" };
    var statusLabels = new[] { "全部状态", "已预约", "已取消" };
}

<h4 class="mb-3">预约管理</h4>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" action="/Admin/Reservations" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">状态</label>
                <select name="status" class="form-select">
                    @for (var i = 0; i < statuses.Length; i++)
                    {
                        <option value="@statuses[i]" selected="@(currentStatus == statuses[i])">@statusLabels[i]</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">开始日期</label>
                <input type="date" name="dateFrom" class="form-control" value="@currentDateFrom" />
            </div>
            <div class="col-md-3">
                <label class="form-label">结束日期</label>
                <input type="date" name="dateTo" class="form-control" value="@currentDateTo" />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">筛选</button>
            </div>
        </form>
    </div>
</div>

@if (Model.Items.Count == 0)
{
    <div class="card">
        <div class="card-body text-center py-5">
            <h5 class="text-muted">暂无匹配的预约记录</h5>
            <a href="/Admin/Reservations" class="btn btn-outline-primary mt-2">重置筛选</a>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>用户</th>
                        <th>座位</th>
                        <th>日期</th>
                        <th>时段</th>
                        <th>状态</th>
                        <th>创建时间</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.UserName</td>
                            <td>@item.SeatNumber</td>
                            <td>@item.Date.ToString("yyyy-MM-dd")</td>
                            <td>@item.TimeSlot</td>
                            <td>
                                @if (item.Status == "已预约")
                                {
                                    <span class="badge bg-primary">已预约</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">已取消</span>
                                }
                            </td>
                            <td class="text-muted small">@item.CreatedAt.ToString("MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
