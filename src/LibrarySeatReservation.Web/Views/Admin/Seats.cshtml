@model List<Seat>
@{
    ViewData["Title"] = "座位管理";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">座位管理</h4>
    <a href="/Admin/SeatCreate" class="btn btn-primary">+ 新增座位</a>
</div>

@if (Model.Count == 0)
{
    <div class="card">
        <div class="card-body text-center py-5">
            <h5 class="text-muted">暂无座位数据</h5>
            <a href="/Admin/SeatCreate" class="btn btn-primary mt-2">新增第一个座位</a>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>编号</th>
                        <th>楼层</th>
                        <th>区域</th>
                        <th>描述</th>
                        <th>状态</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var seat in Model)
                    {
                        <tr>
                            <td>@seat.SeatNumber</td>
                            <td>@seat.Floor 楼</td>
                            <td>@seat.Area</td>
                            <td>@(seat.Description ?? "-")</td>
                            <td>
                                @if (seat.IsActive)
                                {
                                    <span class="badge bg-success seat-status-@seat.Id">启用</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary seat-status-@seat.Id">禁用</span>
                                }
                            </td>
                            <td>
                                <a href="/Admin/SeatEdit/@seat.Id" class="btn btn-sm btn-outline-primary me-1">编辑</a>
                                <button type="button" class="btn btn-sm @(seat.IsActive ? "btn-warning" : "btn-success")" onclick="toggleSeat(@seat.Id)">
                                    @(seat.IsActive ? "禁用" : "启用")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <script>
        function toggleSeat(id) {
            $.post('/Admin/SeatToggle', { id: id }, function (result) {
                if (result.success) {
                    var badge = $('.seat-status-' + id);
                    var btn = badge.closest('tr').find('button');
                    if (result.isActive) {
                        badge.removeClass('bg-secondary').addClass('bg-success').text('启用');
                        btn.removeClass('btn-success').addClass('btn-warning').text('禁用');
                    } else {
                        badge.removeClass('bg-success').addClass('bg-secondary').text('禁用');
                        btn.removeClass('btn-warning').addClass('btn-success').text('启用');
                    }
                } else {
                    alert(result.message || '操作失败');
                }
            }).fail(function () {
                alert('请求失败，请刷新后重试');
            });
        }
    </script>
}
