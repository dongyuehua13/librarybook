<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 管理端</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand" href="/">图书馆座位预约 - 管理端</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/Seats">座位管理</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/Reservations">预约管理</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/Stats">数据统计</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <span class="nav-link text-light">
                                <span class="badge bg-light text-dark me-1">管理员</span>
                                @Context.Session.GetString("AdminName")
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/">返回首页</a>
                        </li>
                        <li class="nav-item">
                            <button type="button" class="nav-link btn btn-link" onclick="document.getElementById('logoutForm').submit();">退出登录</button>
                            <form id="logoutForm" action="/Admin/Logout" method="post" class="d-none"></form>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="container mt-4">
        @RenderBody()
    </main>

    <footer class="border-top mt-5 py-3 text-center text-muted small">
        &copy; 2026 图书馆座位预约系统 - 管理端
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
